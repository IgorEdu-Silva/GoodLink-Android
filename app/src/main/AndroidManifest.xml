<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.GET_ACCOUNTS"/>
    <uses-permission android:name="android.permission.USE_CREDENTIALS"/>

    <queries>
        <intent>
            <action android:name="android.intent.action.VIEW" />

            <data android:scheme="http" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />

            <data android:scheme="https" />
        </intent>
    </queries>

    <application
        android:name=".app.ApplicationClass"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@drawable/ic_goodlink"
        android:label="@string/app_name"
        android:roundIcon="@drawable/ic_goodlink"
        android:screenOrientation="portrait"
        android:textSize="14sp"
        android:supportsRtl="true"
        android:theme="@style/Theme.GoodLink"
        tools:ignore="DiscouragedApi"
        tools:targetApi="31">

        <activity
            android:name=".feature.legal.ui.PolicyActivity"
            android:exported="false" />
        <activity
            android:name=".feature.auth.ui.UserAccount"
            android:exported="false" />

        <meta-data
            android:name="com.google.android.gms.version"
            android:value="@integer/google_play_services_version" />

        <activity
            android:name=".feature.forum.ui.popup.PopUpReport"
            android:exported="false"
            android:label="@string/title_activity_pop_up_report"
            tools:ignore="Instantiatable,LockedOrientationActivity" />
        <activity
            android:name=".feature.forum.ui.popup.PopUpComment"
            android:exported="false"
            tools:ignore="LockedOrientationActivity" />
        <activity
            android:name=".feature.auth.ui.resetpass.ResetPassActivity"
            android:exported="false"
            tools:ignore="LockedOrientationActivity" />
        <activity
            android:name=".feature.legal.ui.TermsAcitivity"
            android:exported="false" />
        <activity
            android:name=".feature.auth.ui.register.RegisterActivity"
            android:exported="false"
            tools:ignore="LockedOrientationActivity" />
        <activity
            android:name=".feature.forum.ui.ForumActivity"
            android:exported="false"
            tools:ignore="LockedOrientationActivity" />
        <activity
            android:name=".feature.forum.ui.login.LoginActivity"
            android:exported="true"
            tools:ignore="LockedOrientationActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>